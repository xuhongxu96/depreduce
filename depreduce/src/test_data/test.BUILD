load("@rules_cc//cc:cc_binary.bzl", "cc_binary")

cc_binary(
    name = "main"  ,
    srcs = ["main.cpp"],
    deps = [
        "//liba", # hi
        "//libb" # hihi
        ,
        "//libc"
    ],
)

cc_binary(
    name = "main2",
    srcs = ["main2.cpp"],
    deps = [
        "//libx", # hi
        "//liby",
        "//libz"
    ],
)