    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in library 'buildfuzz'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--lib",
                    "--package=buildfuzz"
                ],
                "filter": {
                    "name": "buildfuzz",
                    "kind": "lib"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'buildfuzz'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=buildfuzz",
                    "--package=buildfuzz"
                ],
                "filter": {
                    "name": "buildfuzz",
                    "kind": "bin"
                }
            },
            "args": [
                "--input",
                "${workspaceFolder}/examples/simple-cxx-project",
                "-a",
                "${workspaceFolder}/examples/simple-cxx-project/bazel-bin",
                "-c",
                "${workspaceFolder}/buildfuzz/src/test_data/build.sh"
            ],
            "cwd": "${workspaceFolder}"
        },
